# --- Server Side Configuration ---
PORT=3001
NODE_ENV=production

# MongoDB Connection String (Replace with your Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bingo

# Security
ADMIN_SECRET=generate_a_random_string_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Use @userinfobot on Telegram to get your actual numeric User ID
ADMIN_CHAT_ID=123456789

# --- Client Side Configuration (Vite requires VITE_ prefix) ---
# The URL where your backend is hosted (e.g., on Render)
VITE_BACKEND_URL=https://your-backend-api.onrender.com

# The URL where your frontend is hosted (for CORS configuration)
FRONTEND_URL=https://your-app-name.vercel.app

# The username of your Telegram Bot (without the @)
VITE_TELEGRAM_BOT_USERNAME=WesternBingo_bot
