# Server-side Environment Variables
PORT=3001
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"
ADMIN_SECRET="YOUR_ADMIN_SECRET_KEY_HERE" # Make this a strong, unique key for API authentication
MONGODB_URI="YOUR_MONGODB_CONNECTION_STRING_HERE"
ADMIN_CHAT_ID="YOUR_TELEGRAM_ADMIN_CHAT_ID_HERE"

# Client-side Environment Variables (Vite)
# VITE_BACKEND_URL is used by the frontend to make API calls to the backend.
VITE_BACKEND_URL="http://localhost:3001" # For local development, or your deployed backend URL (e.g., https://your-app.onrender.com)
# VITE_API_URL is used by the admin-bot for internal API calls to the backend. It should typically be the same as VITE_BACKEND_URL.
VITE_API_URL="http://localhost:3001" # For local development, or your deployed backend URL (e.g., https://your-app.onrender.com)
VITE_TELEGRAM_BOT_USERNAME="LomyBingo75_bot" # e.g., LomyBingo75_bot (without the @). IMPORTANT: Replace this with your actual bot username.