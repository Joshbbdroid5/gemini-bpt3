# Server-side Environment Variables
PORT=3001
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"
ADMIN_SECRET="YOUR_ADMIN_SECRET_KEY_HERE" # Make this a strong, unique key
MONGODB_URI="YOUR_MONGODB_CONNECTION_STRING_HERE"
ADMIN_CHAT_ID="YOUR_TELEGRAM_ADMIN_CHAT_ID_HERE"

# Client-side Environment Variables (Vite)
VITE_BACKEND_URL="http://localhost:3001" # Or your deployed backend URL
VITE_TELEGRAM_BOT_USERNAME="YOUR_BOT_USERNAME_HERE" # e.g., @LomiBingoAdminBot